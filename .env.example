# Runtime config is auto-written to ~/.claude-usage-tracker/config.env by auth.py.
# This file is for reference only.

# Poll cadence for API samples and frontend refresh.
POLL_INTERVAL_SECONDS=60

# Dashboard bind address.
DASHBOARD_HOST=127.0.0.1
DASHBOARD_PORT=7474

# Expected weekly usage guideline line on the chart.
# If true, a dashed line is drawn from weekly reset to weekly reset, reaching 100% at reset.
EXPECTED_WEEKLY_LINE_ENABLED=true

# Active daily window (HH:MM, local browser time) used for expected weekly line progression.
EXPECTED_ACTIVE_START_HHMM=08:00
EXPECTED_ACTIVE_END_HHMM=19:00

# Auto-populated after first login.
CLAUDE_ORG_ID=
CLAUDE_COOKIE_HEADER=
ANTHROPIC_DEVICE_ID=
ANTHROPIC_ANONYMOUS_ID=

# Optional override for request fingerprint.
USER_AGENT=Mozilla/5.0 (X11; Linux x86_64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/122.0.0.0 Safari/537.36
